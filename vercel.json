{
  "version": 2,
  "redirects": [
    {
      "source": "/download",
      "destination": "https://play.google.com/store/apps/details?id=app.vercel.sanay3i_matrouh.twa&pcampaignid=web_share",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/status",
      "destination": "/status.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/worker/(.*)",
      "destination": "/worker.html"
    },
    {
      "source": "/trade/(.*)/area/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/trade/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/area/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
