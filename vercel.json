{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/admin/?",
      "dest": "/admin.html"
    },
    {
      "src": "/admin-add-worker/?",
      "dest": "/admin-add-worker.html"
    },
    {
      "src": "/admin/add-worker/?",
      "dest": "/admin-add-worker.html"
    },
    {
      "src": "/register/?",
      "dest": "/register.html"
    },
    {
      "src": "/status/?",
      "dest": "/status.html"
    },
    {
      "src": "/worker/(.*)",
      "dest": "/worker.html"
    },
    {
      "src": "/trade/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/area/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "api/server.js"
    }
  ]
}